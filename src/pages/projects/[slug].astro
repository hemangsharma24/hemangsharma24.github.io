---
import Layout from "@/layouts/Layout.astro";
import TagRow from "@/components/TagRow.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const bgMap: Record<string, string> = {
  gintaa: "#D4BF96",
  fnol:   "#4A2880",
  bosch:  "#5C1A1A",
  bolna:  "#192B1A",
};

const fgMap: Record<string, string> = {
  gintaa: "#1E0D0D",
  fnol:   "#F9F5F0",
  bosch:  "#F9F5F0",
  bolna:  "#F9F5F0",
};

const imageMap: Record<string, string> = {
  gintaa: "/gintaa-project.png",
  fnol:   "/fnol-project.png",
  bosch:  "/bosch-project.png",
  bolna:  "/bolna-project.png",
};

const heroBg = bgMap[entry.data.theme];
const heroFg = fgMap[entry.data.theme];
const img = imageMap[entry.data.theme];

const borderColor = heroFg === "#1E0D0D"
  ? "rgba(30,13,13,0.18)"
  : "rgba(249,245,240,0.15)";

const allProjects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const currentIndex = allProjects.findIndex((p) => p.data.slug === entry.data.slug);
const prev = currentIndex > 0 ? allProjects[currentIndex - 1] : null;
const next = currentIndex < allProjects.length - 1 ? allProjects[currentIndex + 1] : null;
---

<Layout title={entry.data.title} description={entry.data.blurb}>

  <!-- Themed hero -->
  <div style={`background: ${heroBg}; color: ${heroFg};`}>
    <div style={`max-width: var(--max-w-page); margin: 0 auto; padding: 2.5rem var(--px-page) 0;`}>

      <!-- Breadcrumb -->
      <nav style="margin-bottom: 2rem;">
        <a href="/projects"
          style={`font-family: var(--font-mono); font-size: var(--text-label); color: ${heroFg}; opacity: 0.6; text-decoration: none; letter-spacing: var(--tracking-wide);`}>
          ← Projects
        </a>
        {entry.data.category && (
          <>
            <span style={`font-family: var(--font-mono); font-size: var(--text-label); opacity: 0.35; margin: 0 0.5rem;`}>/</span>
            <span style={`font-family: var(--font-mono); font-size: var(--text-label); opacity: 0.5; letter-spacing: var(--tracking-wide);`}>{entry.data.category}</span>
          </>
        )}
      </nav>

      <!-- Tags -->
      <div style={`font-family: var(--font-mono); font-size: var(--text-label); color: ${heroFg}; display: flex; align-items: center; gap: 0.5rem; letter-spacing: var(--tracking-wide); text-transform: uppercase; opacity: 0.65; margin-bottom: 1.5rem;`}>
        <span>{entry.data.number}</span>
        {entry.data.type.map((tag, i) => (
          <>
            <span style="opacity: 0.5;">·</span>
            <span>{tag}</span>
          </>
        ))}
      </div>

      <!-- Tagline heading -->
      <h1 style={`font-family: var(--font-display); font-size: clamp(1.75rem, 4vw, 4rem); letter-spacing: var(--tracking-tight); line-height: var(--leading-tight); margin: 0 0 2.5rem; max-width: 22ch;`}>
        {entry.data.tagline}
      </h1>

      <!-- Stats bar -->
      {entry.data.stats && entry.data.stats.length > 0 && (
        <div class="stats-bar" style={`display: grid; grid-template-columns: repeat(${entry.data.stats.length}, 1fr); border-top: 1px solid ${borderColor}; border-bottom: 1px solid ${borderColor}; --stats-border: ${borderColor};`}>
          {entry.data.stats.map(({ label, value }, i) => (
            <div class="stats-cell" style={`padding: 1.25rem ${i > 0 ? "1.5rem" : "0"}; ${i > 0 ? `border-left: 1px solid ${borderColor};` : ""}`}>
              <p style={`font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: var(--tracking-wide); text-transform: uppercase; opacity: 0.5; margin: 0 0 0.35rem;`}>{label}</p>
              <p style={`font-family: var(--font-body); font-size: var(--text-body); margin: 0; font-weight: 500;`}>{value}</p>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Hero image -->
    <div style={`max-width: var(--max-w-page); margin: 0 auto; padding: 2rem var(--px-page) 0;`}>
      <div style={`
        width: 100%;
        height: 22rem;
        border-radius: 0.75rem 0.75rem 0 0;
        overflow: hidden;
        border: 1px solid ${borderColor};
        border-bottom: none;
      `}>
        <img
          src={img}
          alt={entry.data.title}
          style="width: 100%; height: 100%; object-fit: cover; object-position: center 22%;"
        />
      </div>
    </div>
  </div>

  <!-- Case study body (light bg) -->
  <article
    style={`max-width: 72ch; margin: 0 auto; padding: var(--section-gap) var(--px-content);`}
    class="prose"
  >
    <Content />
  </article>

  <!-- Prev / Next -->
  <nav class="prev-next-nav" style={`max-width: var(--max-w-page); margin: 0 auto; padding: 0 var(--px-page) var(--section-gap); display: flex; justify-content: space-between; border-top: 1px solid var(--color-border); padding-top: 2.5rem;`}>
    <div>
      {prev && (
        <a href={`/projects/${prev.data.slug}`}
          style={`font-family: var(--font-body); font-size: var(--text-body); color: var(--color-ink); text-decoration: none;`}>
          ← {prev.data.title}
        </a>
      )}
    </div>
    <div>
      {next && (
        <a href={`/projects/${next.data.slug}`}
          style={`font-family: var(--font-body); font-size: var(--text-body); color: var(--color-ink); text-decoration: none;`}>
          {next.data.title} →
        </a>
      )}
    </div>
  </nav>

</Layout>

<style>
  @media (max-width: 639px) {
    .stats-bar {
      grid-template-columns: repeat(2, 1fr) !important;
    }

    .stats-cell {
      border-left: none !important;
      padding: 1rem 0.75rem !important;
    }

    /* Re-add separator between col 1 and col 2 in each row */
    .stats-cell:nth-child(even) {
      border-left: 1px solid var(--stats-border) !important;
    }

    .prev-next-nav {
      flex-direction: column;
      gap: 1rem;
    }
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    letter-spacing: var(--tracking-tight);
    text-transform: uppercase;
    margin: 3.5rem 0 1rem;
    color: var(--color-ink);
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: var(--text-body-lg);
    letter-spacing: var(--tracking-tight);
    margin: 2rem 0 0.75rem;
    color: var(--color-ink);
  }
  .prose :global(p) {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--color-muted);
    margin: 0 0 1.25rem;
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 3rem 0;
  }
  .prose :global(ul), .prose :global(ol) {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--color-muted);
    padding-left: 1.5rem;
    margin: 0 0 1.25rem;
  }
  .prose :global(li) { margin-bottom: 0.5rem; }
  .prose :global(strong) { color: var(--color-ink); font-weight: 600; }
  .prose :global(blockquote) {
    border-left: 2px solid var(--color-border);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
  }
  .prose :global(blockquote p) { color: var(--color-ink); opacity: 0.85; }
  .prose :global(ol) { list-style-type: decimal; }
</style>
