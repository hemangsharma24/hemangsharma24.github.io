---
import Layout from "@/layouts/Layout.astro";
import ExperienceRow from "@/components/ExperienceRow.astro";
import TestimonialGrid from "@/components/TestimonialGrid.astro";
import { experience } from "@/data/experience";
import { testimonials } from "@/data/testimonials";

const education = [
  {
    credential: "Advanced Certificate in Innovation & User Experience Design",
    institution: "MIT Institute of Design",
    period: "August 2023 – September 2024",
  },
  {
    credential: "Bachelor of Science in Animation and Multimedia",
    institution: "Birla Institute of Technology",
    period: "July 2019 – December 2022",
  },
];

const certifications = [
  { credential: "UX Design Professional Certificate", institution: "Google Certification" },
  { credential: "Digital Skills: User Experience", institution: "Accenture Certification" },
  { credential: "Adobe UX Foundations", institution: "Adobe" },
];
---

<Layout title="About" description="About Hemang Sharma — UI/UX Product Designer based in Jaipur, India.">

  <!-- Hero -->
  <section style={`max-width: var(--max-w-page); margin: 0 auto; padding: var(--section-gap) var(--px-page) 4rem;`}>
    <div class="about-hero-grid">
      <div>
        <p style={`font-family: var(--font-mono); font-size: var(--text-label); color: var(--color-muted); letter-spacing: var(--tracking-wide); text-transform: uppercase; margin: 0 0 2rem;`}>About</p>
        <h1 style={`font-family: var(--font-display); font-size: clamp(2rem, 3.2vw, 4rem); letter-spacing: var(--tracking-tight); line-height: var(--leading-tight); margin: 0 0 2rem; color: var(--color-ink);`}>
          Hello, I'm Hemang Sharma — UI UX Designer based in Jaipur. Most recently Founding Designer at OverseeAI.
        </h1>
        <p style={`font-family: var(--font-body); font-size: var(--text-body-lg); line-height: var(--leading-body); color: var(--color-muted); margin: 0 0 1.5rem;`}>
          My role at OverseeAI revolved around shipping the product end-to-end, from first wireframes to launch. I worked alongside ML engineers and insurance domain experts to make complex AI workflows feel simple.
        </p>
        <p style={`font-family: var(--font-body); font-size: var(--text-body); line-height: var(--leading-body); color: var(--color-muted); margin: 0;`}>
          Before that, I spent over two years at Divum Corporate Services working on enterprise B2B platforms and customer experience portals for clients including Bosch. I care about the intersection of decision-making and interface design.
        </p>
      </div>

      <div style="display: flex; justify-content: flex-end;">
        <div
          style={`
            width: 100%; max-width: 22rem; aspect-ratio: 3/4;
            border-radius: 0.75rem; background: var(--color-surface);
            border: 1px solid var(--color-border);
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            overflow: hidden; position: relative;
          `}
        >
          <svg width="100%" height="100%" viewBox="0 0 320 420" preserveAspectRatio="xMidYMid slice" style="position: absolute; inset: 0; opacity: 0.06;">
            <defs>
              <pattern id="dot-grid-about" width="20" height="20" patternUnits="userSpaceOnUse">
                <circle cx="10" cy="10" r="1.5" fill="#1E0D0D"/>
              </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#dot-grid-about)"/>
          </svg>
          <div style="position: relative; text-align: center; padding: 2rem;">
            <div style={`width: 4rem; height: 4rem; border-radius: 50%; background: var(--color-border); margin: 0 auto 1rem; display: flex; align-items: center; justify-content: center;`}>
              <span style={`font-family: var(--font-display); font-size: 1.25rem; color: var(--color-ink); opacity: 0.35;`}>HS</span>
            </div>
            <p style={`font-family: var(--font-mono); font-size: var(--text-label); color: var(--color-muted); letter-spacing: var(--tracking-wide); text-transform: uppercase; margin: 0 0 0.25rem; opacity: 0.6;`}>Hemang Sharma</p>
            <p style={`font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-muted); letter-spacing: var(--tracking-wide); text-transform: uppercase; opacity: 0.4; margin: 0;`}>UI/UX Product Designer</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Work Experience -->
  <section style={`max-width: var(--max-w-page); margin: 0 auto; padding: 0 var(--px-page) var(--section-gap); border-top: 1px solid var(--color-border); padding-top: var(--section-gap);`}>
    <h2 style={`font-family: var(--font-display); font-size: var(--text-h2); letter-spacing: var(--tracking-tight); text-transform: uppercase; margin: 0 0 2.5rem; color: var(--color-ink);`}>Work Experience</h2>
    <div style={`border-top: 1px solid var(--color-border);`}>
      {experience.map((exp) => (
        <ExperienceRow role={exp.role} company={exp.company} period={exp.period} location={exp.location} type={exp.type} />
      ))}
    </div>
  </section>

  <!-- Education -->
  <section style={`max-width: var(--max-w-page); margin: 0 auto; padding: 0 var(--px-page) var(--section-gap); border-top: 1px solid var(--color-border); padding-top: var(--section-gap);`}>
    <h2 style={`font-family: var(--font-display); font-size: var(--text-h2); letter-spacing: var(--tracking-tight); text-transform: uppercase; margin: 0 0 2.5rem; color: var(--color-ink);`}>Education</h2>
    <div style={`border-top: 1px solid var(--color-border);`}>
      {education.map(({ credential, institution, period }) => (
        <div class="edu-cert-row">
          <div>
            <p style={`font-family: var(--font-body); font-size: var(--text-body); margin: 0 0 0.25rem; color: var(--color-ink);`}>{credential}</p>
            <p style={`font-family: var(--font-body); font-size: var(--text-label); color: var(--color-muted); margin: 0;`}>{institution}</p>
          </div>
          <p class="edu-cert-meta" style={`font-family: var(--font-mono); font-size: var(--text-label); color: var(--color-muted); margin: 0;`}>{period}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Certifications -->
  <section style={`max-width: var(--max-w-page); margin: 0 auto; padding: 0 var(--px-page) var(--section-gap);`}>
    <h2 style={`font-family: var(--font-display); font-size: var(--text-h2); letter-spacing: var(--tracking-tight); text-transform: uppercase; margin: 0 0 2.5rem; color: var(--color-ink);`}>Certifications</h2>
    <div style={`border-top: 1px solid var(--color-border);`}>
      {certifications.map(({ credential, institution }) => (
        <div class="edu-cert-row">
          <p style={`font-family: var(--font-body); font-size: var(--text-body); margin: 0; color: var(--color-ink);`}>{credential}</p>
          <p class="edu-cert-meta" style={`font-family: var(--font-mono); font-size: var(--text-label); color: var(--color-muted); margin: 0; opacity: 0.7;`}>{institution}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Testimonials -->
  <section style={`max-width: var(--max-w-page); margin: 0 auto; padding: 0 var(--px-page) var(--section-gap); border-top: 1px solid var(--color-border); padding-top: var(--section-gap);`}>
    <h2 style={`font-family: var(--font-display); font-size: var(--text-h2); letter-spacing: var(--tracking-tight); text-transform: uppercase; margin: 0 0 2.5rem; color: var(--color-ink);`}>Testimonials</h2>
    <TestimonialGrid {testimonials} />
  </section>

  <!-- Off the Clock -->
  <section style={`max-width: var(--max-w-page); margin: 0 auto; padding: 0 var(--px-page) var(--section-gap); border-top: 1px solid var(--color-border); padding-top: var(--section-gap);`}>
    <h2 style={`font-family: var(--font-display); font-size: var(--text-h2); letter-spacing: var(--tracking-tight); text-transform: uppercase; margin: 0 0 2.5rem; color: var(--color-ink);`}>Off the Clock</h2>
    <p style={`font-family: var(--font-body); font-size: var(--text-body-lg); line-height: var(--leading-body); color: var(--color-muted); margin: 0 0 1.5rem;`}>
      Off the grid, I'm a music explorer who enjoys Linkin Park, Radiohead and Jagjit Singh, a Football fanatic, and a Movie buff with a very long watchlist. I also enjoy writing philosophical thoughts, short poems, and reflections inspired by everyday life.
    </p>
    <p style={`font-family: var(--font-body); font-size: var(--text-body); line-height: var(--leading-body); color: var(--color-muted); margin: 0 0 3rem;`}>
      I'm open to freelance opportunities, collaborations, and meaningful conversations around design, AI products, cinema or ideas worth building.
    </p>
    <a href="mailto:kshamahemang@gmail.com"
      style={`font-family: var(--font-body); font-size: var(--text-body); color: var(--color-cream); background: var(--color-ink); padding: 0.75rem 1.5rem; border-radius: 2rem; text-decoration: none; display: inline-block;`}>
      kshamahemang@gmail.com →
    </a>
  </section>

</Layout>

<style>
  .about-hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .edu-cert-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: start;
    padding: 1.375rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  @media (min-width: 640px) and (max-width: 1023px) {
    .about-hero-grid {
      gap: 2.5rem;
    }
  }

  @media (max-width: 639px) {
    .about-hero-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .edu-cert-row {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }

    .edu-cert-meta {
      white-space: normal;
    }
  }
</style>
