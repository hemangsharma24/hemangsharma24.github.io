---
import LogoMark from "./LogoMark.tsx";
---

<footer style="background-color: var(--color-ink); color: var(--color-cream); margin-top: var(--section-gap);">
  <div style={`max-width: var(--max-w-page); margin: 0 auto; padding: var(--px-content) var(--px-page);`}>

    <!-- Main footer row -->
    <div class="footer-main">

      <!-- Logo mark -->
      <LogoMark client:visible />

      <!-- Info -->
      <div>
        <p style={`font-family: var(--font-display); font-size: 2rem; letter-spacing: var(--tracking-tight); margin: 0 0 0.25rem; color: var(--color-cream);`}>
          Hemang Sharma
        </p>
        <p style={`font-family: var(--font-body); font-size: var(--text-body); color: rgba(244,237,217,0.5); margin: 0 0 1.25rem;`}>
          UI UX Designer | Product Designer
        </p>
        <a
          href="mailto:kshamahemang@gmail.com"
          style={`font-family: var(--font-body); font-size: var(--text-body); color: rgba(244,237,217,0.65); text-decoration: none; display: block; margin-bottom: 1.5rem;`}
        >
          kshamahemang@gmail.com
        </a>

        <!-- Social icons -->
        <div style="display: flex; gap: 0.75rem;">
          <a
            href="https://www.linkedin.com/in/hemangsharma24/"
            target="_blank"
            rel="noopener noreferrer"
            title="LinkedIn"
            style={`
              width: 2.25rem; height: 2.25rem;
              border-radius: 0.375rem;
              background: rgba(244,237,217,0.12);
              display: flex; align-items: center; justify-content: center;
              text-decoration: none;
            `}
          >
            <img src="/home_page_assets/Footer/footer linkedin-3 1.svg" width="20" height="20" alt="LinkedIn" style="display: block; filter: brightness(1.5);" />
          </a>
          <a
            href="https://www.behance.net/hemangsharma24"
            target="_blank"
            rel="noopener noreferrer"
            title="Behance"
            style={`
              width: 2.25rem; height: 2.25rem;
              border-radius: 0.375rem;
              background: rgba(244,237,217,0.12);
              display: flex; align-items: center; justify-content: center;
              text-decoration: none;
            `}
          >
            <img src="/home_page_assets/Footer/Footer iconmonstr-behance-3 (1) 1.svg" width="20" height="20" alt="Behance" style="display: block; filter: brightness(1.5);" />
          </a>
        </div>
      </div>

      <!-- View Resume -->
      <a
        href="/resume.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-resume-btn"
        style={`font-family: var(--font-body); font-size: var(--text-body); color: var(--color-ink); background: var(--color-cream); padding: 0.75rem 1.5rem; border-radius: 2rem; text-decoration: none; white-space: nowrap; align-self: start;`}
      >
        View Resume
      </a>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p style={`font-family: var(--font-mono); font-size: var(--text-label); color: rgba(244,237,217,0.35); margin: 0;`}>
        © May 2026, Hemang Sharma
      </p>
      <p style={`font-family: var(--font-mono); font-size: var(--text-label); color: rgba(244,237,217,0.35); margin: 0;`}>
        Designed through ideas, iterations and late nights ~ -^
      </p>
    </div>

  </div>
</footer>

<style>
  .footer-main {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 4rem;
    align-items: center;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--color-border-dark);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.25rem;
  }

  @media (max-width: 639px) {
    .footer-main {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding-bottom: 2rem;
    }

    .footer-resume-btn {
      display: inline-block;
      text-align: center;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }

  @media (min-width: 640px) and (max-width: 1023px) {
    .footer-main {
      grid-template-columns: auto 1fr;
      gap: 2rem;
    }

    .footer-resume-btn {
      grid-column: 1 / -1;
    }
  }
</style>
