---
interface Props {
  number: string;
  title: string;
  tags: string[];
  blurb: string;
  href: string;
  theme: "gintaa" | "fnol" | "bosch" | "bolna";
  category?: string;
  imageRight?: boolean;
}

const { number, title, tags, blurb, href, theme, category, imageRight = true } = Astro.props;

const bgMap: Record<string, string> = {
  gintaa: "#D4BF96",
  fnol:   "#4A2880",
  bosch:  "#5C1A1A",
  bolna:  "#192B1A",
};

const fgMap: Record<string, string> = {
  gintaa: "#1E0D0D",
  fnol:   "#F9F5F0",
  bosch:  "#F9F5F0",
  bolna:  "#F9F5F0",
};

const imageMap: Record<string, string> = {
  gintaa: "/home_page_assets/Featured Projects Section/GINTAA Card.png",
  fnol:   "/home_page_assets/Featured Projects Section/Claims Insurance Card.png",
  bosch:  "/home_page_assets/Featured Projects Section/BOSCH CX Card.png",
  bolna:  "/home_page_assets/Featured Projects Section/BOLNA Card.png",
};

const bg = bgMap[theme];
const fg = fgMap[theme];
const img = imageMap[theme];

const borderColor = fg === "#1E0D0D"
  ? "rgba(30,13,13,0.18)"
  : "rgba(249,245,240,0.15)";
const mutedFg = fg === "#1E0D0D"
  ? "rgba(30,13,13,0.55)"
  : "rgba(249,245,240,0.6)";
---

<a
  href={href}
  class="featured-card"
  data-parallax-card
  style={`background: ${bg}; color: ${fg};`}
>
  <!-- Text column -->
  <div
    class="card-text"
    style={`order: ${imageRight ? 0 : 1};`}
  >
    <div>
      {category && (
        <p style={`font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 1.25rem; color: ${mutedFg};`}>
          {category}
        </p>
      )}
      <p style={`font-family: var(--font-mono); font-size: var(--text-label); margin: 0 0 0.5rem; opacity: 0.5;`}>{number}</p>
      <div style={`display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1rem;`}>
        {tags.map((tag) => (
          <span style={`font-family: var(--font-body); font-size: 0.8rem; color: ${fg}; opacity: 0.7;`}>
            {tag}
          </span>
        )).reduce((acc, el, i) => {
          if (i === 0) return [el];
          return [...acc, <span style={`opacity: 0.35; font-size: 0.8rem;`}>•</span>, el];
        }, [] as any[])}
      </div>
      <h3 style={`font-family: var(--font-display); font-size: clamp(1.25rem, 2vw, var(--text-h3)); letter-spacing: var(--tracking-tight); margin: 0 0 1rem; text-transform: uppercase; line-height: var(--leading-tight);`}>
        {title}
      </h3>
      <p style={`font-family: var(--font-body); font-size: var(--text-body); line-height: var(--leading-body); opacity: 0.8; margin: 0; max-width: 38ch;`}>
        {blurb}
      </p>
    </div>

    <div style="margin-top: 2rem;">
      <span
        style={`
          font-family: var(--font-body); font-size: var(--text-body);
          display: inline-flex; align-items: center; gap: 0.5rem;
          border: 1px solid ${borderColor};
          padding: 0.6rem 1.25rem;
          border-radius: 2rem;
          color: ${fg};
        `}
      >
        Read Case Study <img src="/home_page_assets/Featured Projects Section/Arrow.svg" width="16" height="16" alt="" style={`display: inline-block; vertical-align: middle; margin-left: 0.25rem;${fg !== "#1E0D0D" ? " filter: brightness(0) invert(1);" : ""}`} />
      </span>
    </div>
  </div>

  <!-- Image column -->
  <div
    class="card-image"
    style={`order: ${imageRight ? 1 : 0};`}
  >
    <div
      style={`
        position: absolute;
        inset: 1.5rem;
        border-radius: 0.5rem;
        overflow: hidden;
        background: ${fg === "#1E0D0D" ? "rgba(30,13,13,0.1)" : "rgba(249,245,240,0.06)"};
      `}
    >
      <img
        data-parallax-img
        src={img}
        alt={title}
        class="card-parallax-img"
        style="width: 100%; height: 100%; object-fit: contain; object-position: center center; transform: scale(1.12) translateY(0px);"
        loading="lazy"
      />
    </div>
  </div>
</a>

<style>
  .featured-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-radius: 0.75rem;
    text-decoration: none;
    overflow: hidden;
    min-height: 22rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    will-change: transform;
  }

  [data-parallax-img] {
    will-change: transform;
  }

  .card-text {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 2.5rem;
  }

  .card-image {
    overflow: hidden;
    position: relative;
  }

  @media (max-width: 639px) {
    .featured-card {
      grid-template-columns: 1fr;
      min-height: unset;
    }

    .card-text {
      order: 0 !important;
      padding: 1.75rem;
    }

    .card-image {
      order: 1 !important;
      height: 20rem;
    }

    .card-image > div {
      position: absolute;
      inset: 0 !important;
      border-radius: 0 !important;
    }
  }

  @media (min-width: 640px) and (max-width: 1023px) {
    .card-text {
      padding: 2rem;
    }
  }
</style>

<script>
(function () {
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isTouchDevice  = window.matchMedia('(hover: none)').matches;
  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-parallax-card]'));
  if (!cards.length) return;

  // ── Scroll parallax on images ──────────────────────────────────────────
  if (!prefersReduced) {
    let scrollRafPending = false;

    function updateScrollParallax() {
      const vh = window.innerHeight;
      const viewportCenter = vh / 2;

      cards.forEach(card => {
        const img = card.querySelector<HTMLElement>('[data-parallax-img]');
        if (!img) return;
        const rect = card.getBoundingClientRect();
        const cardCenter = rect.top + rect.height / 2;
        const maxDistance = viewportCenter + rect.height / 2;
        const normalized = Math.max(-1, Math.min(1, (cardCenter - viewportCenter) / maxDistance));
        const translateY = normalized * 30;
        img.style.transform = `scale(1.12) translateY(${translateY}px)`;
      });

      scrollRafPending = false;
    }

    updateScrollParallax();

    window.addEventListener('scroll', () => {
      if (!scrollRafPending) {
        scrollRafPending = true;
        requestAnimationFrame(updateScrollParallax);
      }
    }, { passive: true });
  }

  // ── Mouse tilt on cards (desktop only) ────────────────────────────────
  if (!isTouchDevice) {
    const TILT_MAX = 5;
    const rafHandles = new WeakMap<HTMLElement, number>();

    cards.forEach(card => {
      card.addEventListener('mousemove', (e: MouseEvent) => {
        if (rafHandles.has(card)) cancelAnimationFrame(rafHandles.get(card)!);

        const id = requestAnimationFrame(() => {
          const rect = card.getBoundingClientRect();
          const normX = (e.clientX - (rect.left + rect.width  / 2)) / (rect.width  / 2);
          const normY = (e.clientY - (rect.top  + rect.height / 2)) / (rect.height / 2);
          const rotateY =  normX * TILT_MAX;
          const rotateX = -normY * TILT_MAX;

          card.style.transition = 'box-shadow 0.3s ease';
          card.style.transform  = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateZ(0)`;
          card.style.boxShadow  = '0 12px 40px rgba(0,0,0,0.2)';
          rafHandles.delete(card);
        });

        rafHandles.set(card, id);
      });

      card.addEventListener('mouseleave', () => {
        if (rafHandles.has(card)) {
          cancelAnimationFrame(rafHandles.get(card)!);
          rafHandles.delete(card);
        }
        card.style.transition = 'transform 0.4s ease, box-shadow 0.3s ease';
        card.style.transform  = 'perspective(1000px) rotateX(0deg) rotateY(0deg) translateZ(0)';
        card.style.boxShadow  = 'none';
      });
    });
  }
})();
</script>
