---
interface Props {
  number: string;
  title: string;
  tags: string[];
  blurb: string;
  href: string;
  theme: "gintaa" | "fnol" | "bosch" | "bolna";
  category?: string;
  imageRight?: boolean;
}

const { number, title, tags, blurb, href, theme, category, imageRight = true } = Astro.props;

const bgMap: Record<string, string> = {
  gintaa: "#D4BF96",
  fnol:   "#4A2880",
  bosch:  "#5C1A1A",
  bolna:  "#192B1A",
};

const fgMap: Record<string, string> = {
  gintaa: "#1E0D0D",
  fnol:   "#F9F5F0",
  bosch:  "#F9F5F0",
  bolna:  "#F9F5F0",
};

const imageMap: Record<string, string> = {
  gintaa: "/gintaa-project.png",
  fnol:   "/fnol-project.png",
  bosch:  "/bosch-project.png",
  bolna:  "/bolna-project.png",
};

const imagePosMap: Record<string, string> = {
  gintaa: "center 22%",
  fnol:   "center 18%",
  bosch:  "center 20%",
  bolna:  "center 18%",
};

const bg = bgMap[theme];
const fg = fgMap[theme];
const img = imageMap[theme];
const imgPos = imagePosMap[theme];

const borderColor = fg === "#1E0D0D"
  ? "rgba(30,13,13,0.18)"
  : "rgba(249,245,240,0.15)";
const mutedFg = fg === "#1E0D0D"
  ? "rgba(30,13,13,0.55)"
  : "rgba(249,245,240,0.6)";
---

<a
  href={href}
  style={`
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: ${bg};
    color: ${fg};
    border-radius: 0.75rem;
    text-decoration: none;
    overflow: hidden;
    min-height: 22rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  `}
  onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 12px 40px rgba(0,0,0,0.2)'"
  onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='none'"
>
  <!-- Text column -->
  <div
    style={`
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 2.5rem;
      order: ${imageRight ? 0 : 1};
    `}
  >
    <div>
      {category && (
        <p style={`font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 1.25rem; color: ${mutedFg};`}>
          {category}
        </p>
      )}
      <p style={`font-family: var(--font-mono); font-size: var(--text-label); margin: 0 0 0.5rem; opacity: 0.5;`}>{number}</p>
      <div style={`display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1rem;`}>
        {tags.map((tag) => (
          <span style={`font-family: var(--font-body); font-size: 0.8rem; color: ${fg}; opacity: 0.7;`}>
            {tag}
          </span>
        )).reduce((acc, el, i) => {
          if (i === 0) return [el];
          return [...acc, <span style={`opacity: 0.35; font-size: 0.8rem;`}>•</span>, el];
        }, [] as any[])}
      </div>
      <h3 style={`font-family: var(--font-display); font-size: clamp(1.25rem, 2vw, var(--text-h3)); letter-spacing: var(--tracking-tight); margin: 0 0 1rem; text-transform: uppercase; line-height: var(--leading-tight);`}>
        {title}
      </h3>
      <p style={`font-family: var(--font-body); font-size: var(--text-body); line-height: var(--leading-body); opacity: 0.8; margin: 0; max-width: 38ch;`}>
        {blurb}
      </p>
    </div>

    <div style="margin-top: 2rem;">
      <span
        style={`
          font-family: var(--font-body); font-size: var(--text-body);
          display: inline-flex; align-items: center; gap: 0.5rem;
          border: 1px solid ${borderColor};
          padding: 0.6rem 1.25rem;
          border-radius: 2rem;
          color: ${fg};
        `}
      >
        Read Case Study →
      </span>
    </div>
  </div>

  <!-- Image column -->
  <div
    style={`
      order: ${imageRight ? 1 : 0};
      overflow: hidden;
      position: relative;
    `}
  >
    <div
      style={`
        position: absolute;
        inset: 1.5rem;
        border-radius: 0.5rem;
        overflow: hidden;
        background: ${fg === "#1E0D0D" ? "rgba(30,13,13,0.1)" : "rgba(249,245,240,0.06)"};
      `}
    >
      <img
        src={img}
        alt={title}
        style={`
          width: 100%;
          height: 100%;
          object-fit: cover;
          object-position: ${imgPos};
          transform: scale(1.02);
        `}
        loading="lazy"
      />
    </div>
  </div>
</a>
