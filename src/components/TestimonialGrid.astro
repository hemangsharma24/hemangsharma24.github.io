---
interface Testimonial {
  name: string;
  nameNote?: string;
  role: string;
  initials: string;
  avatar?: string;
  quote: string;
  attribution?: string;
}

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;

const avatarColors = [
  { bg: "#E8F4FD", text: "#1A5276" },
  { bg: "#FEF9E7", text: "#7D6608" },
  { bg: "#F5EEF8", text: "#6C3483" },
  { bg: "#E8F8F5", text: "#1A5742" },
];
---

<div class="testimonial-grid">
  {testimonials.map(({ name, nameNote, role, initials, avatar, quote }, i) => {
    const colors = avatarColors[i % avatarColors.length];
    return (
      <div style={`background: var(--color-cream); border: 1px solid var(--color-border); border-left: 3px solid var(--color-border-hero); border-radius: 0; padding: 1.75rem; display: flex; flex-direction: column; gap: 1.25rem;`}>
        <!-- Header: avatar + name -->
        <div style="display: flex; align-items: center; gap: 0.875rem;">
          {avatar ? (
            <img
              src={avatar}
              alt={name}
              width="44"
              height="44"
              style="width: 2.75rem; height: 2.75rem; border-radius: 50%; object-fit: cover; flex-shrink: 0;"
            />
          ) : (
            <div
              style={`
                width: 2.75rem; height: 2.75rem; border-radius: 50%;
                background: ${colors.bg};
                color: ${colors.text};
                display: flex; align-items: center; justify-content: center;
                font-family: var(--font-body); font-size: 0.875rem; font-weight: 700;
                flex-shrink: 0;
              `}
            >
              {initials}
            </div>
          )}
          <div>
            <p style={`font-family: var(--font-body); font-size: var(--text-body); font-weight: 600; margin: 0 0 0.1rem; color: var(--color-ink);`}>
              {name}{nameNote && <span style={`font-weight: 400; color: var(--color-muted); font-size: var(--text-label);`}> {nameNote}</span>}
            </p>
            <p style={`font-family: var(--font-body); font-size: var(--text-label); color: var(--color-muted); margin: 0;`}>
              {role}
            </p>
          </div>
        </div>

        <!-- Quote -->
        <div>
          <span style={`font-family: var(--font-display); font-size: 3.5rem; line-height: 0.5; color: var(--color-border-hero); opacity: 0.6; display: block; margin-bottom: 0.5rem;`}>"</span>
          <p style={`font-family: var(--font-body); font-size: var(--text-body); line-height: var(--leading-body); color: var(--color-ink); margin: 0; font-style: italic;`}>
            {quote}
          </p>
        </div>
      </div>
    );
  })}
</div>

<style>
  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--color-border);
  }

  @media (max-width: 639px) {
    .testimonial-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
